
{
  //1.配置 maven
  "maven.terminal.useJavaHome": true,
  "java.jdt.ls.java.home": "E:\\java\\openjdk-22.0.2_windows-x64_bin\\jdk-21",
  // 配置 maven命令所在的路径
  "maven.executable.path": "E:\\java\\apache-maven-3.9.1\\bin\\mvn",
  // maven配置文件, 若不指定则会使用 maven.executable.path所属Maven的settings.xml
  "maven.settingsFile": "E:\\java\\apache-maven-3.9.1\\conf\\settings.xml",

  //2.配置JDK，类似于IDEA中配置JDK，可以在Project Settings中选择，用于项目启动
  "java.configuration.runtimes": [
      {
          "name": "JavaSE-17",
          "path": "E:\\java\\openjdk-22.0.2_windows-x64_bin\\jdk-17",
          "default": false
      },
      {
          "name": "JavaSE-21",
          "path": "E:\\java\\openjdk-22.0.2_windows-x64_bin\\jdk-21",
          "default": true
      },
      {
          "name": "JavaSE-1.8",
          "path": "E:\\java\\openjdk-22.0.2_windows-x64_bin\\jdk1.8.0_202",
          "default": false
      }
  ],
  // 3.配置Git
  "git.path": "E:\\Git\\bin\\git.exe"
}
